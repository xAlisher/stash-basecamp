{
  "name": "stash",
  "version": "0.1.0",
  "type": "core",
  "category": "storage",
  "description": "Lean decentralised storage — drop a file, get a CID back",
  "main": "stash_plugin",
  "icon": "",
  "dependencies": [],

  "nix": {
    "packages": {
      "build": ["libsodium", "pkg-config"],
      "runtime": ["libsodium"]
    },
    "external_libraries": [
      { "name": "logos_storage_nim", "vendor_path": "third_party/logos-storage-nim" }
    ],
    "cmake": {
      "find_packages": ["Qt6 COMPONENTS Core Qml Network"],
      "extra_sources": [
        "src/core/StashBackend.cpp",
        "src/core/StorageClient.cpp",
        "src/core/PinningClient.cpp",
        "src/core/LibStorageTransport.cpp",
        "src/plugin/StashPlugin.cpp"
      ],
      "extra_include_dirs": [
        "src",
        "third_party/logos-storage-nim/include"
      ],
      "extra_link_libraries": [
        "Qt6::Network",
        "${LOGOS_STORAGE_NIM_LIB}/libstorage.a",
        "${LOGOS_STORAGE_NIM_LIB}/libbacktrace.a",
        "${LOGOS_STORAGE_NIM_LIB}/libminiupnpc.a",
        "${LOGOS_STORAGE_NIM_LIB}/libnatpmp.a",
        "dl",
        "pthread"
      ]
    }
  }
}
